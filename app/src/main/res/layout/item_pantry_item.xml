<?xml version="1.0" encoding="utf-8"?>
<!--
    Dense single-line pantry row.
    Left:  ingredient name  (BodyLarge, full weight)
    Right: quantity + unit  (BodyMedium, muted colour)

    The card view and vertical stack are gone. This is a flat, full-width touch target
    with a bottom divider drawn by StickyHeaderDecoration — no extra View needed.

    MinHeight 48dp keeps the touch target within Material accessibility guidelines.
    The row is the swipe surface; no edit button — tap anywhere to edit.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="48dp"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/textName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:ellipsize="end"
        android:maxLines="1" />

    <TextView
        android:id="@+id/textDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

</LinearLayout>
